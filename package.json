		"simple-git": "^3.32.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@types/node": "^22.0.0",
		"memfs": "^4.0.0",
		"tsup": "^8.5.0",
		"typescript": "~5.9.3",
		"vitest": "^4.0.18"
	}
}
