{
	"name": "ai-sync",
	"version": "0.2.1",
	"type": "module",
	"bin": {
		"ai-sync": "./dist/cli.js"
	},
	"scripts": {
		"build": "tsup",
		"test": "vitest run --reporter=verbose",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
